#include <stdio.h>
#include <stdlib.h>
#include <pthread.h>
#include <semaphore.h>
#include <unistd.h>

#define N 5

sem_t forks[N];

sem_t room;

pthread_mutex_t mutex;

void* philosopher(void* num)

{

    int id = *(int*)num;

    while (1) {

        pthread_mutex_lock(&mutex);

        printf("Philosopher %d is thinking\n", id);

        pthread_mutex_unlock(&mutex);

        sleep(1);

        // Allow only N-1 philosophers in the room

        sem_wait(&room);

        // Pick up forks

        sem_wait(&forks[id]);

        sem_wait(&forks[(id + 1) % N]);

        // Eating

        pthread_mutex_lock(&mutex);

        printf("Philosopher %d is eating\n", id);

        pthread_mutex_unlock(&mutex);

        sleep(2);

        // Put down forks

        sem_post(&forks[id]);

        sem_post(&forks[(id + 1) % N]);

        // Leave room

        sem_post(&room);

        // Finished eating

        pthread_mutex_lock(&mutex);

        printf("Philosopher %d finished eating\n", id);

        pthread_mutex_unlock(&mutex);

        sleep(1);

    }

    return NULL;

}

int main() {

    pthread_t thread[N];

    int phil_num[N];

    pthread_mutex_init(&mutex, NULL);

    // Initialize room semaphore to N-1

    sem_init(&room, 0, N - 1);

    // Initialize fork semaphores

    for (int i = 0; i < N; i++) {

        sem_init(&forks[i], 0, 1);

    }

    // Create philosopher threads

    for (int i = 0; i < N; i++) {

        phil_num[i] = i;

        pthread_create(&thread[i], NULL, philosopher, &phil_num[i]);

    }

    // Join threads (runs indefinitely)

    for (int i = 0; i < N; i++) {

        pthread_join(thread[i], NULL);

    }

    return 0;

}
