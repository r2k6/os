#include <stdio.h>
struct process{
    int id, tat, bt, wt, pt;
} p[10], temp;
int main()
{
    int i, j, n;
    printf("Enter the number of processes: ");
    scanf("%d", &n);
    for(i = 0; i < n; i++) {
        printf("Enter id, burst time and priority: ");
        scanf("%d %d %d", &p[i].id, &p[i].bt, &p[i].pt);
    }
    for(i = 0; i < n; i++) {
        for(j = 0; j < n-i-1; j++) {
           if(p[j].pt > p[j+1].pt) {
                temp = p[j];
                p[j] = p[j+1];
                p[j+1] = temp;
            }
        }
    }

    p[0].wt = 0;
    p[0].tat = p[0].bt;
    for(i = 1; i < n; i++) {
        p[i].wt = p[i-1].tat;
        p[i].tat = p[i].bt + p[i].wt;
    }
    printf("\nID\tBT\tPT\tWT\tTAT\n");
    for(i = 0; i < n; i++)
        printf("%d\t%d\t%d\t%d\t%d\n",
               p[i].id, p[i].bt, p[i].pt, p[i].wt, p[i].tat);
    return 0;
}
