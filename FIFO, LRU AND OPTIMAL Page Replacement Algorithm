#include <stdio.h>

#define MAX 50

void fifo(int pages[], int n, int f) {

    int frame[MAX], i, j, k = 0, found, faults = 0;

    for (i = 0; i < f; i++)
        frame[i] = -1;

    for (i = 0; i < n; i++) {

        found = 0;

        for (j = 0; j < f; j++)

            if (frame[j] == pages[i])
                found = 1;

        if (!found) {

            frame[k] = pages[i];

            k = (k + 1) % f;

            faults++;

        }

    }

    printf("FIFO Page Faults = %d\n", faults);

}

void lru(int pages[], int n, int f) {

    int frame[MAX], time[MAX], i, j, pos, faults = 0, t = 0;

    for (i = 0; i < f; i++)
        frame[i] = -1;

    for (i = 0; i < n; i++) {

        int found = 0;

        for (j = 0; j < f; j++) {

            if (frame[j] == pages[i]) {

                found = 1;

                time[j] = ++t;

            }

        }

        if (!found) {

            int min = 9999;

            for (j = 0; j < f; j++) {

                if (frame[j] == -1) {

                    pos = j;

                    break;

                }

                if (time[j] < min) {

                    min = time[j];

                    pos = j;

                }

            }

            frame[pos] = pages[i];

            time[pos] = ++t;

            faults++;

        }

    }

    printf("LRU Page Faults = %d\n", faults);

}

void optimal(int pages[], int n, int f) {

    int frame[MAX], i, j, k, pos, faults = 0;

    for (i = 0; i < f; i++)
        frame[i] = -1;

    for (i = 0; i < n; i++) {

        int found = 0;

        for (j = 0; j < f; j++)

            if (frame[j] == pages[i])
                found = 1;

        if (!found) {

            int farthest = -1;

            for (j = 0; j < f; j++) {

                int next = -1;

                for (k = i + 1; k < n; k++) {

                    if (frame[j] == pages[k]) {

                        next = k;

                        break;

                    }

                }

                if (next == -1) {

                    pos = j;

                    break;

                }

                if (next > farthest) {

                    farthest = next;

                    pos = j;

                }

            }

            frame[pos] = pages[i];

            faults++;

        }

    }

    printf("Optimal Page Faults = %d\n", faults);

}

int main() {

    int pages[MAX], n, f, i;

    printf("Enter number of pages: ");

    scanf("%d", &n);

    printf("Enter page reference string: ");

    for (i = 0; i < n; i++)
        scanf("%d", &pages[i]);

    printf("Enter number of frames: ");

    scanf("%d", &f);

    fifo(pages, n, f);

    lru(pages, n, f);

    optimal(pages, n, f);

    return 0;

}
