#include <stdio.h>

struct process {
    int id, bt, wt, tat, rt;
} p[10];

int main() {
    int i, n, tq, time = 0, done;
    float avg_wt = 0, avg_tat = 0;

    printf("Enter number of processes: ");
    scanf("%d", &n);

    for (i = 0; i < n; i++) {
        printf("Enter process id and burst time: ");
        scanf("%d %d", &p[i].id, &p[i].bt);
        p[i].rt = p[i].bt;
    }

    printf("Enter time quantum: ");
    scanf("%d", &tq);

    while (1) {
        done = 1;

        for (i = 0; i < n; i++) {
            if (p[i].rt > 0) {
                done = 0;

                if (p[i].rt > tq) {
                    time += tq;
                    p[i].rt -= tq;
                } else {
                    time += p[i].rt;
                    p[i].wt = time - p[i].bt;
                    p[i].rt = 0;
                }
            }
        }

        if (done == 1)
            break;
    }

    printf("\nPID\tBT\tWT\tTAT\n");
    printf("--------------------------------\n");

    for (i = 0; i < n; i++) {
        p[i].tat = p[i].bt + p[i].wt;
        avg_wt  += p[i].wt;
        avg_tat += p[i].tat;
        printf("P%d\t%d\t%d\t%d\n",
               p[i].id, p[i].bt, p[i].wt, p[i].tat);
    }

    printf("--------------------------------\n");
    printf("Average Waiting Time:      %.2f\n", avg_wt  / n);
    printf("Average Turnaround Time:   %.2f\n", avg_tat / n);

    return 0;
}
