#include <stdio.h>
#include <pthread.h>
#include <semaphore.h>
#include <unistd.h>

sem_t resource, readTry, rmutex, wmutex;
int readCount = 0, writeCount = 0;

void *reader(void *arg) {

    sem_wait(&readTry);

    sem_wait(&rmutex);

    readCount++;

    if (readCount == 1)

        sem_wait(&resource);

    sem_post(&rmutex);

    sem_post(&readTry);

    printf("Reader %ld is reading\n", (long)arg);

    sleep(1);

    sem_wait(&rmutex);

    readCount--;

    if (readCount == 0)

        sem_post(&resource);

    sem_post(&rmutex);

    return NULL;
}

void *writer(void *arg) {

    sem_wait(&wmutex);

    writeCount++;

    if (writeCount == 1)

        sem_wait(&readTry);

    sem_post(&wmutex);

    sem_wait(&resource);

    printf("Writer %ld is writing\n", (long)arg);

    sleep(1);

    sem_post(&resource);

    sem_wait(&wmutex);

    writeCount--;

    if (writeCount == 0)

        sem_post(&readTry);

    sem_post(&wmutex);

    return NULL;
}

int main() {

    pthread_t r[3], w[2];

    sem_init(&resource, 0, 1);

    sem_init(&readTry, 0, 1);

    sem_init(&rmutex, 0, 1);

    sem_init(&wmutex, 0, 1);

    for (long i = 0; i < 3; i++)

        pthread_create(&r[i], NULL, reader, (void *)i);

    for (long i = 0; i < 2; i++)

        pthread_create(&w[i], NULL, writer, (void *)i);

    for (int i = 0; i < 3; i++)

        pthread_join(r[i], NULL);

    for (int i = 0; i < 2; i++)

        pthread_join(w[i], NULL);

    return 0;
}
