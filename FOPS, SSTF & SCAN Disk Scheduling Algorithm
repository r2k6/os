#include <stdio.h>
#include <stdlib.h>

#define MAX 100

void fcfs(int req[], int n, int head) {

    int seek = 0, i;

    for (i = 0; i < n; i++) {

        seek += abs(head - req[i]);

        head = req[i];

    }

    printf("FCFS Seek Time = %d\n", seek);

}

void sstf(int req[], int n, int head) {

    int visited[MAX] = {0};

    int seek = 0, i, j, min, index;

    for (i = 0; i < n; i++) {

        min = 9999;

        for (j = 0; j < n; j++) {

            if (!visited[j]) {

                int dist = abs(head - req[j]);

                if (dist < min) {

                    min = dist;

                    index = j;

                }

            }

        }

        seek += min;

        head = req[index];

        visited[index] = 1;

    }

    printf("SSTF Seek Time = %d\n", seek);

}

void scan(int req[], int n, int head, int size) {

    int seek = 0, i, j, temp;

    int left[MAX], right[MAX], l = 0, r = 0;

    for (i = 0; i < n; i++) {

        if (req[i] < head)

            left[l++] = req[i];

        else

            right[r++] = req[i];

    }

    for (i = 0; i < l - 1; i++) {

        for (j = 0; j < l - i - 1; j++) {

            if (left[j] > left[j + 1]) {

                temp = left[j];

                left[j] = left[j + 1];

                left[j + 1] = temp;

            }

        }

    }

    for (i = 0; i < r - 1; i++) {

        for (j = 0; j < r - i - 1; j++) {

            if (right[j] > right[j + 1]) {

                temp = right[j];

                right[j] = right[j + 1];

                right[j + 1] = temp;

            }

        }

    }

    for (i = 0; i < r; i++) {

        seek += abs(head - right[i]);

        head = right[i];

    }

    seek += abs(head - (size - 1));

    head = size - 1;

    for (i = l - 1; i >= 0; i--) {

        seek += abs(head - left[i]);

        head = left[i];

    }

    printf("SCAN Seek Time = %d\n", seek);

}

int main() {

    int req[MAX], n, head, size, i;

    printf("Enter number of requests: ");

    scanf("%d", &n);

    printf("Enter request sequence: ");

    for (i = 0; i < n; i++)

        scanf("%d", &req[i]);

    printf("Enter initial head position: ");

    scanf("%d", &head);

    printf("Enter disk size: ");

    scanf("%d", &size);

    fcfs(req, n, head);

    sstf(req, n, head);

    scan(req, n, head, size);

    return 0;

}
