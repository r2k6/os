Addition.c

#include <stdio.h>
#include <stdlib.h>

int main(int argc, char *argv[])
{
    int a, b, sum;

    /* Check if exactly two numbers are passed */
    if (argc != 3)
    {
        printf("Usage: ./addition num1 num2\n");
        return 1;
    }

    /* Convert string arguments to integers */
    a = atoi(argv[1]);
    b = atoi(argv[2]);

    /* Add the two numbers */
    sum = a + b;

    printf("\n  %d + %d = %d\n", a, b, sum);

    return 0;
}

forkexec.c

/*
 * forkexec.c
 * Creates a child process using fork()
 * Child executes addition.c using execvp()
 */

#include <stdio.h>
#include <stdlib.h>
#include <unistd.h>
#include <sys/wait.h>

int main()
{
    pid_t pid;

    printf("===========================\n");
    printf("  Fork and Exec Program\n");
    printf("===========================\n");

    /* Step 1: Create child process */
    pid = fork();

    /* Step 2: fork() failed */
    if (pid < 0)
    {
        perror("Fork failed");
        return 1;
    }

    /* Step 3: Child process */
    else if (pid == 0)
    {
        printf("\n[CHILD]  PID     : %d\n", getpid());
        printf("[CHILD]  Executing addition...\n");

        /* Pass two numbers as arguments to addition */
        char *args[] = {"./addition", "5", "7", NULL};
        execvp(args[0], args);

        /* Reached only if execvp fails */
        perror("execvp failed");
        exit(1);
    }

    /* Step 4: Parent process */
    else
    {
        printf("\n[PARENT] PID     : %d\n", getpid());
        printf("[PARENT] Waiting for child...\n");

        /* Wait for child to finish */
        wait(NULL);

        printf("[PARENT] Child finished\n");
        printf("[PARENT] Exiting\n");
        printf("===========================\n");
    }

    return 0;
}



COMBINED CODE

#include <stdio.h>
#include <stdlib.h>
#include <unistd.h>
#include <sys/wait.h>

/* addition function (replaces addition.c) */
void addition(int a, int b)
{
    int sum = a + b;
    printf("\n  %d + %d = %d\n", a, b, sum);
}

int main()
{
    pid_t pid;

    printf("===========================\n");
    printf("  Fork and Exec Program\n");
    printf("===========================\n");

    /* Create child process */
    pid = fork();

    /* fork() failed */
    if (pid < 0)
    {
        perror("Fork failed");
        return 1;
    }

    /* Child process */
    else if (pid == 0)
    {
        printf("\n[CHILD]  PID     : %d\n", getpid());
        printf("[CHILD]  Executing addition...\n");

        /* Call addition directly */
        addition(5, 7);

        exit(0);
    }

    /* Parent process */
    else
    {
        printf("\n[PARENT] PID     : %d\n", getpid());
        printf("[PARENT] Waiting for child...\n");

        wait(NULL);

        printf("[PARENT] Child finished\n");
        printf("[PARENT] Exiting\n");
        printf("===========================\n");
    }

    return 0;
}
