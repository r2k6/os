#include <stdio.h>
#include <stdlib.h>
int main(int argc, char *argv[])
{
    int a, b, sum;
    if(argc != 3){
        printf("Usage: ./myadd num1 num2\n");
        return 1;
    }
    a = atoi(argv[1]);
    b = atoi(argv[2]);
    sum = a + b;
    printf("Sum = %d\n", sum);
    return 0;
}

Program 2 Using fork() and execvp() (forkexec.c)

#include <stdio.h>
#include <unistd.h>
#include <sys/wait.h>

int main()
{
    int pid;
    pid = fork();
    if(pid == 0){
        char *args[] = {"./myadd", "5", "7", NULL};
        execvp(args[0], args);
    }
    else{
        wait(NULL);
        printf("Child process completed\n");
    }
    return 0;
}
